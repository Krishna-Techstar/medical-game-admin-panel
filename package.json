{
  "name": "medical-game-admin-panel",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm --workspace=client run dev",
    "dev:server": "npm --workspace=server run dev",
    "build:client": "npm --workspace=client run build",
    "start:server": "npm --workspace=server start",
    "dev": "concurrently \"npm --workspace=server run dev\" \"npm --workspace=client run dev\"",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
